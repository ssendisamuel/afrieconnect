# App
APP_NAME=AfrieConnect
APP_URL=http://localhost:3600
APP_URL_DYNAMIC=true
TRUST_PROXY=false
PORT=3600
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afrieconnect
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM_FOR_PRODUCTION_USE
JWT_EXPIRES=7d

# Admin Account (created on first run)
ADMIN_EMAIL=ssendi.samuel@gmail.com
ADMIN_PASSWORD=Admin@AfrieConnect2026!
ADMIN_NAME=Samuel Ssendi
ADMIN_PHONE=256779265701

# SMS billing (UGX per 160-char part, used when EgoSMS doesn't return cost)
SMS_RATE_UGX=40
SMS_RATE_FREE=30
SMS_RATE_STARTER=30
SMS_RATE_BUSINESS=25
SMS_RATE_ENTERPRISE=25

# Flutterwave V4 (Mobile Money top-ups)
FLUTTERWAVE_CLIENT_ID=YOUR_FLW_CLIENT_ID
FLUTTERWAVE_CLIENT_SECRET=YOUR_FLW_CLIENT_SECRET
FLUTTERWAVE_ENCRYPTION_KEY=YOUR_FLW_ENCRYPTION_KEY
# Live V4: https://f4bexperience.flutterwave.com
# Sandbox V4: https://developersandbox-api.flutterwave.com
FLUTTERWAVE_API_BASE=https://f4bexperience.flutterwave.com
FLUTTERWAVE_WEBHOOK_SECRET=YOUR_FLW_WEBHOOK_SECRET

# EgoSMS / Pahappa CommsSDK
EGOSMS_USERNAME=samuelssendi
EGOSMS_PASSWORD=YOUR_EGOSMS_API_KEY
EGOSMS_SENDER_ID=AfrieCon
EGOSMS_BASE_URL=https://comms.egosms.co/api/v1/json/

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AfrieConnect Bulk Services <info@afriezon.com>

# SMS provider webhooks (optional — append ?secret=value to webhook URLs)
SMS_WEBHOOK_SECRET=

# Sessions storage path
SESSIONS_PATH=./wa_sessions
