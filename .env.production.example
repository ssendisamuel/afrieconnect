# Production environment — copy to .env on the VPS (never commit .env)

APP_NAME=AfrieConnect
APP_URL=https://afrieconnect.afriezon.com
APP_URL_DYNAMIC=false
TRUST_PROXY=true
PORT=3600
NODE_ENV=production

# cPanel / VPS MySQL (from hosting panel)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afriezon_afrieco
DB_USER=afriezon_afrieco
DB_PASS=your_database_password_here

# Security — generate long random strings
JWT_SECRET=generate_a_random_string_at_least_64_characters_long_for_production
JWT_EXPIRES=7d

# SMS billing (UGX per 160-char part)
SMS_RATE_UGX=40
SMS_RATE_FREE=30
SMS_RATE_STARTER=30
SMS_RATE_BUSINESS=25
SMS_RATE_ENTERPRISE=25
# Optional: your EgoSMS cost per part for admin margin display
SMS_PROVIDER_COST_UGX=25

# Flutterwave V4 (live)
FLUTTERWAVE_CLIENT_ID=
FLUTTERWAVE_CLIENT_SECRET=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_API_BASE=https://f4bexperience.flutterwave.com
FLUTTERWAVE_WEBHOOK_SECRET=

# EgoSMS — also editable in Admin → SMS Gateways
EGOSMS_USERNAME=
EGOSMS_PASSWORD=
EGOSMS_SENDER_ID=AfrieCon
EGOSMS_BASE_URL=https://comms.egosms.co/api/v1/json/

# SMS provider webhooks (optional shared secret)
SMS_WEBHOOK_SECRET=

# Email — also editable in Admin → Email Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AfrieConnect Bulk Services <info@afriezon.com>

# Disable mock SMS in production (default off when NODE_ENV=production)
ALLOW_MOCK_INTEGRATIONS=false

SESSIONS_PATH=./wa_sessions
